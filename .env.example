# =============================================================================
# mcv6 — Environment Variables
# =============================================================================
# Bu dosyayı .env'e kopyala ve değerleri doldur.
# Tüm secret'ları openssl rand -hex 32 ile üret.
# .env asla commit ETME (gitignored).

# -----------------------------------------------------------------------------
# CORE (ZORUNLU — proje çalışmaz yoksa)
# -----------------------------------------------------------------------------

# Postgres bağlantı string
DATABASE_URL=postgres://USER@localhost:5432/DB

# Payload JWT/session encryption
PAYLOAD_SECRET=replace-me

# Site URL (CORS + canonical + meta tags için)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# CORE (önerilen — secret üret)
# -----------------------------------------------------------------------------

# Vercel/cron job auth
CRON_SECRET=replace-me

# Draft preview validation
PREVIEW_SECRET=replace-me

# -----------------------------------------------------------------------------
# LOCALE (middleware için)
# -----------------------------------------------------------------------------

# Virgülle ayrılmış aktif locale'lar (tek dil için: tr)
PUBLIC_LOCALES=tr,en

# Accept-Language eşleşmediğinde fallback locale
PUBLIC_DEFAULT_LOCALE=tr

# =============================================================================
# PLUGIN ENV'LERİ — Her biri ilgili plugin wire edildiğinde aktif
# =============================================================================

# -----------------------------------------------------------------------------
# @payloadcms/storage-s3 — Production media storage (S3 / R2 / MinIO)
# -----------------------------------------------------------------------------
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1
S3_BUCKET=
# AWS S3 için boş bırak; R2/MinIO için custom endpoint URL
S3_ENDPOINT=

# -----------------------------------------------------------------------------
# @payloadcms/email-resend — Transactional email
# -----------------------------------------------------------------------------
# Resend dashboard'dan al: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=mcv6

# -----------------------------------------------------------------------------
# @payloadcms/plugin-sentry (Bugsink uyumlu) — Hata izleme
# -----------------------------------------------------------------------------
# Bugsink self-hosted instance'ından al (Sentry-uyumlu DSN format).
# Sentry SaaS kullanıyorsan aynı değişken — DSN'i oradan al.
BUGSINK_DSN=

# -----------------------------------------------------------------------------
# @oversightstudio/encrypted-fields — AES field-level encryption (KVKK)
# -----------------------------------------------------------------------------
# 64-char hex (openssl rand -hex 32).
# UYARI: KAYBEDİLİRSE encrypted field'lardaki veri OKUNAMAZ. Yedekle!
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# payload-auth-plugin (Better Auth) — 2FA + OAuth
# -----------------------------------------------------------------------------
# Better Auth signing secret (openssl rand -hex 32)
AUTH_SECRET=

# OAuth provider credentials (opsiyonel — sadece kullanacağın provider'a doldur)

# Google Workspace SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft / Office 365
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Form Captcha — admin'de FormSettings global'inden hangi sağlayıcı seçilirse
# o çalışır. İki sağlayıcı arasında SEÇİM yapılır; ikisini birden set etmeye gerek yok.
# -----------------------------------------------------------------------------

# Option A — Cloudflare Turnstile
# Dashboard: https://dash.cloudflare.com → Turnstile → site oluştur
CLOUDFLARE_TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=

# Option B — Google reCAPTCHA v3
# Dashboard: https://www.google.com/recaptcha/admin → v3 site key
# v3 skoru 0.0-1.0 döner; threshold 0.5 (server-side hardcoded, gerekirse formSpamGuard.ts'te değiştir)
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# -----------------------------------------------------------------------------
# Diğer plugin'ler (env GEREKMEZ)
# -----------------------------------------------------------------------------
# payload-rbac                       — Sadece role-based access control
# @payload-bites/broken-link-checker — Cron schedule plugin config'inde
